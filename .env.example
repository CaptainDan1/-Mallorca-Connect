# Globales Seiten-Passwort fuer Mallorca-Connect (server-only)
PAGE_PASSWORD=

# Optionales Admin-Passwort fuer /admin (server-only).
# Wenn leer, gilt PAGE_PASSWORD auch fuer den Adminbereich.
ADMIN_PASSWORD=

# Supabase (oeffentlich, im Browser verwendbar)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service-Role-Key (server-only!). Wird nur fuer Admin-
# Server-Routen gebraucht, die RLS umgehen muessen (z.B. endgueltiges
# Loeschen aller inaktiven Aktivitaeten). NIEMALS mit NEXT_PUBLIC_
# prefixen und niemals im Browser-Code verwenden.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Admin-Benachrichtigung per E-Mail bei neuen Vorschlaegen.
# Alle drei muessen gesetzt sein, sonst wird die E-Mail uebersprungen
# (der Vorschlag wird trotzdem in Supabase gespeichert).
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
NOTIFICATION_FROM_EMAIL=
